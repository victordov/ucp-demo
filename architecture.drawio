<mxfile host="app.diagrams.net" agent="cowork" version="24.0.0">
  <diagram id="ucp-ap2-arch" name="UCP + AP2 Architecture">
    <mxGraphModel dx="1400" dy="900" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2160" pageHeight="1420" math="0" shadow="0">
      <root>
