        <mxCell id="lg_s" value="── solid: signed UCP / AP2 call&#10;(JSON-RPC 2.0 over MCP, RFC 9421-signed)" style="text;html=1;align=left;verticalAlign=middle;fontSize=10;fontColor=#1F4E79;" vertex="1" parent="legend">
