        <!-- ===================== Title ===================== -->
        <mxCell id="title" value="UCP + AP2 Reference Suite — Architecture" style="text;html=1;align=center;verticalAlign=middle;fontSize=20;fontStyle=1;fontColor=#1A1A1A;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="2080" height="30" as="geometry" />
        </mxCell>
        <mxCell id="subtitle" value="Agentic commerce · JSON-RPC 2.0 over MCP · PKI (ES256 / JWK) HTTP-message signatures, no DID · AP2 mandates as SD-JWT+kb" style="text;html=1;align=center;verticalAlign=middle;fontSize=12;fontColor=#5A6472;" vertex="1" parent="1">
          <mxGeometry x="40" y="52" width="2080" height="20" as="geometry" />
        </mxCell>

